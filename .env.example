# Copy to .env.local and fill in real values. .env.local is gitignored.

# Neon Postgres connection string (pooled). Get it from the Neon dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# Auth.js (NextAuth v5). Generate AUTH_SECRET with: npx auth secret  (or openssl rand -base64 32)
AUTH_SECRET="generate-a-random-32-byte-base64-string"

# Google OAuth — optional. Without these, the game runs in nickname-only mode.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-client-secret"

# OpenAI — optional. Enables the GOAT "Generate my fighter" caricature (gpt-image-1).
# Without it, that button shows "not set up yet". Create at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
